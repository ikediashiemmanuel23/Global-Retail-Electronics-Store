// Measure to calculate Profit Mmargin

Profit Margin % = [Profit] / [Total Sales]

// Measure to calculate Yearly Sales Growth

Sales YOY = 
VAR SCY = [Total Sales]
VAR SLY = [Sales LY]
VAR SYOY = DIVIDE(SCY - SLY, SLY, 0)
VAR _SYOY = 
            SWITCH(TRUE,
                    SYOY > 0, UNICHAR(9650) & " " & FORMAT(SYOY, "0.0%"),
                    SYOY < 0, UNICHAR(9660) & " " & FORMAT(SYOY, "0.0%"),
                    FORMAT(SYOY, "0.O%"))
    RETURN
    _SYOY

// Measure to calculate Unique Custommers

Unique Customers = DISTINCTCOUNT(Sales[CustomerKey])

// Measure to calculate Calculate Custommers Return Rate

Customers Return Rate = 
     VAR ReturningCustomers = COUNTROWS(
                                        Filter(VALUES(Sales[CustomerKey]), 
                                        CALCULATE(DISTINCTCOUNT(Sales[Order ID]))>1)
                                        )
     VAR TotalCustomers = DISTINCTCOUNT(Sales[CustomerKey])
     RETURN
     DIVIDE(ReturningCustomers, TotalCustomers, 0)

// Measure to calculate Average Order Value

Average Order Value = 
DIVIDE([Total Sales], DISTINCTCOUNT(Sales[Order ID]), 0)

// Measure to Calculate Churn Rate

Churn Rate = 
     VAR ReturningCustomers = COUNTROWS(
                                        Filter(VALUES(Sales[CustomerKey]), 
                                        CALCULATE(DISTINCTCOUNT(Sales[Order ID]))>1))
     VAR TotalCustomers = DISTINCTCOUNT(Sales[CustomerKey])
     VAR ChurnedCustomers = TotalCustomers - ReturningCustomers
     RETURN
     DIVIDE(ChurnedCustomers, TotalCustomers, 0)
